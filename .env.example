#Файл предоставлен для примера какие данные нужно в нем хранить

# ==============================================================================
# Django Configuration
# ==============================================================================
DJANGO_PROJECT_NAME=mainsite
DJANGO_SETTINGS_MODULE=mainsite.settings
SECRET_KEY=django-insecure-your-secret-key-placeholder
DEBUG=True

# ==============================================================================
# PostgreSQL Database Configuration
# ==============================================================================
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=your_db_name
SQL_USER=postgres
SQL_PASSWORD=your_secure_password
SQL_HOST=postgres
SQL_PORT=5432

# ==============================================================================
# RabbitMQ (Celery Broker) Configuration
# ==============================================================================
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ==============================================================================
# External Integrations & Services
# ==============================================================================
EMAIL_PASSWORD=your_email_app_password_here
TG_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwxyZ
